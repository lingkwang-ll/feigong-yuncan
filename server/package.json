{
  "name": "feigong-yuncan-server",
  "version": "0.1.0",
  "private": true,
  "description": "非攻云餐 最小可用后端服务 (Express + SQLite)",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-static.js",
    "start": "node dist/index.js",
    "seed": "ts-node-dev --transpile-only src/seed/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "reset:db": "ts-node-dev --transpile-only src/scripts/reset_db.ts",
    "reset:db:seed": "ts-node-dev --transpile-only src/scripts/reset_db.ts -- --seed",
    "clear:orders": "ts-node-dev --transpile-only src/scripts/clear_orders.ts",
    "backup:db": "ts-node-dev --transpile-only src/scripts/backup_db.ts",
    "backup:uploads": "ts-node-dev --transpile-only src/scripts/backup_uploads.ts",
    "prepare:trial": "ts-node-dev --transpile-only src/scripts/prepare_trial_data.ts",
    "seed:trial-users": "ts-node-dev --transpile-only src/scripts/seed_trial_users.ts",
    "seed:commercial": "ts-node-dev --transpile-only src/scripts/seed_commercial.ts",
    "export:today": "ts-node-dev --transpile-only src/scripts/export_today_summary.ts",
    "check:ready": "powershell -ExecutionPolicy Bypass -File ./scripts/check_ready.ps1",
    "check:security": "powershell -ExecutionPolicy Bypass -File ./scripts/security_check.ps1",
    "check:payment-review": "powershell -ExecutionPolicy Bypass -File ./scripts/check_payment_review.ps1",
    "check:overtime-roster-pay": "powershell -ExecutionPolicy Bypass -File ./scripts/check_overtime_roster_pay.ps1",
    "check:overtime-single-use": "powershell -ExecutionPolicy Bypass -File ./scripts/check_overtime_single_use.ps1",
    "check:online-payment-settlement": "powershell -ExecutionPolicy Bypass -File ./scripts/check_online_payment_settlement.ps1",
    "settlement:check": "ts-node-dev --transpile-only scripts/check_settlement.ts",
    "settlement:run": "ts-node-dev --transpile-only scripts/run_settlement.ts",
    "check:dish-quality": "ts-node-dev --transpile-only scripts/check_dish_data_quality.ts",
    "check:display-quality": "ts-node-dev --transpile-only scripts/check_display_data_quality.ts",
    "govern:display-names": "ts-node-dev --transpile-only scripts/govern_display_names.ts",
    "seed:package-demo": "ts-node-dev --transpile-only scripts/seed_package_demo.ts",
    "check:release": "powershell -ExecutionPolicy Bypass -File ./scripts/final_go_live_check.ps1",
    "check:go-live": "powershell -ExecutionPolicy Bypass -File ./scripts/final_go_live_check.ps1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.7.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
