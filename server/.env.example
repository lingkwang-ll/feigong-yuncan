# =========================================
# 非攻云餐 后端环境变量样例
# 复制为 .env 后按需修改；启动时通过 dotenv 自动加载。
# =========================================

# 监听端口
PORT=3000

# 监听地址：默认 0.0.0.0（外网可访问）；本机调试可改 127.0.0.1
HOST=0.0.0.0

# SQLite 数据库文件路径（相对 server/ 目录）
# 兼容旧名 DATABASE_FILE（仍可继续使用），新部署请用 DATABASE_PATH
DATABASE_PATH=./data/feigong-yuncan.db

# 上传根目录（相对 server/ 目录）
# 内部子目录：payments / dishes / qrcodes
UPLOAD_DIR=./uploads

# 静态资源对外公开 URL 前缀
# - 留空：upload 接口返回相对路径 /uploads/xxx/abc.png
# - 配置：返回绝对路径，例如 http://118.31.188.176:3000/uploads/xxx/abc.png
PUBLIC_BASE_URL=http://localhost:3000

# CORS 来源
# - "*"：放开所有（演示 / 内网试运行）
# - 逗号分隔白名单，例：CORS_ORIGIN=http://localhost:5757,http://192.168.0.10:5757
CORS_ORIGIN=*

# JWT（短信登录签发 Token，必填）
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# 短信服务：mock（试运行/内网）| aliyun（生产）
SMS_PROVIDER=mock

# mock 试运行：0=不限制发送频率；不设则默认 0
# SMS_MOCK_SEND_INTERVAL_SEC=0

# aliyun 正式环境频率限制（SMS_PROVIDER=aliyun 时生效）
# SMS_SEND_INTERVAL_SEC=60
# SMS_DAILY_LIMIT=10

# 阿里云短信（SMS_PROVIDER=aliyun 时使用，勿写死在代码中）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# 高德地图 Web JS API（后台参考 / 运维配置，前端通过 dart-define 注入）
AMAP_WEB_KEY=
AMAP_SECURITY_CODE=

# 微信支付（勿提交证书/密钥到 git）
WECHAT_PAY_APPID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=https://yuncan.pheako.com/api/payments/wechat/notify

# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_NOTIFY_URL=https://yuncan.pheako.com/api/payments/alipay/notify
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 在线支付业务开关在 system_config.app_settings.onlinePaymentEnabled 中配置：
#   manualQr=true（首期默认） wechat=false alipay=false
# 正式接入前须补齐上方商户 env，并在 admin 后台打开对应开关。
