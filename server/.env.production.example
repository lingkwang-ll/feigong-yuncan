# =========================================
# 非攻云餐 后端 —— 生产环境样例
#
# 部署到 /opt/feigong-yuncan/server/ 后：
#   cp .env.production.example .env
#   vim .env
# =========================================

NODE_ENV=production

# 监听
HOST=0.0.0.0
PORT=3000

# 数据 / 上传（独立于代码目录，部署升级不丢数据）
DATABASE_PATH=/opt/feigong-yuncan/data/feigong-yuncan.db
UPLOAD_DIR=/opt/feigong-yuncan/uploads

# 对外可访问基地址（Nginx 反代后填域名，不要带 /api 后缀）
# 例：https://yuncan.example.com
PUBLIC_BASE_URL=https://your-domain.com

# 跨域白名单（逗号分隔；生产建议显式列出前端域名）
# 例：https://your-domain.com,https://your-domain.com/admin
CORS_ORIGIN=https://your-domain.com

# JWT（生产必须改为随机长字符串）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# 短信：正式试运行仍用 mock；后续切换 aliyun
SMS_PROVIDER=mock

# 平台管理员手机号（seed:commercial 使用）
PLATFORM_ADMIN_PHONE=13700000000

# 阿里云短信（SMS_PROVIDER=aliyun 时配置，当前留空）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# 微信支付（勿提交证书/密钥到 git；首期留空，开关在 system_config）
WECHAT_PAY_APPID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payments/wechat/notify

# 支付宝（首期留空）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/alipay/notify
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
